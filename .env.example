# Database
DATABASE_URL="postgresql://user:password@localhost:5432/devforum?schema=public"

# Auth (NextAuth v5)
AUTH_SECRET="your-secret-key-min-32-chars"
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""
AUTH_GITLAB_ID=""
AUTH_GITLAB_SECRET=""

# Email (Resend or SMTP)
RESEND_API_KEY=""
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""

# Redis (optional, for caching/rate limiting)
REDIS_URL=""

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Feature flags
ENABLE_EMAIL_AUTH="true"
ENABLE_OAUTH="true"

# Rate limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_MS=900000

# Skip env validation (development only)
SKIP_ENV_VALIDATION=""
